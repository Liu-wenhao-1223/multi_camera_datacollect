[Desktop Entry]
Type=Application
Name=Multi Camera Data Collect
Name[zh_CN]=多相机采集
Comment=Launch Orbbec multi-camera data collection
Exec=/usr/bin/env python3 -c "import os,subprocess; d=os.path.join(os.path.expanduser(\"~\"),\"workspace\",\"multi_camera_datacollect\"); subprocess.Popen([os.path.join(d,\"run_multi_camera_datacollect.sh\")], cwd=d)"
Icon=camera-photo
Terminal=false
Categories=Utility;Science;
StartupNotify=true
